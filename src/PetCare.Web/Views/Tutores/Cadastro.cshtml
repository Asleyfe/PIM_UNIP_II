@{
    ViewData["Title"] = "Novo Tutor";
}

<style>
    .form-card {
        background: #fff; border-radius: var(--radius);
        box-shadow: 0 2px 12px var(--sombra); padding: 32px; max-width: 860px;
    }
    .form-section-title {
        font-size: .8rem; font-weight: 700; letter-spacing: .08em;
        text-transform: uppercase; color: var(--texto-s);
        margin: 24px 0 16px; border-bottom: 1px solid var(--cinza-2); padding-bottom: 8px;
    }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-grid.cols-3 { grid-template-columns: 1fr 1fr 1fr; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group label { font-size: .82rem; font-weight: 600; color: var(--texto-s); }
    .form-group input, .form-group select {
        padding: 10px 14px; border: 1px solid var(--cinza-2); border-radius: var(--radius-s);
        font-family: 'DM Sans', sans-serif; font-size: .9rem; outline: none;
        transition: border-color var(--trans);
    }
    .form-group input:focus, .form-group select:focus { border-color: var(--verde-d); }
    .form-group.full { grid-column: 1 / -1; }
    .form-actions { display: flex; gap: 12px; margin-top: 28px; }
    .btn-cancel {
        padding: 10px 24px; border-radius: 50px; font-weight: 600; cursor: pointer;
        border: 1px solid var(--cinza-2); background: #fff; color: var(--texto-s);
        font-family: 'DM Sans', sans-serif; transition: var(--trans);
    }
    .btn-cancel:hover { background: var(--cinza); }
    @@media(max-width:640px) { .form-grid, .form-grid.cols-3 { grid-template-columns: 1fr; } }
</style>

<div class="header-container" style="margin-bottom:24px">
    <h1 class="page-title">Cadastrar Tutor</h1>
    <a href="/Tutores" class="btn-sm" style="background:var(--cinza);color:var(--texto-s)">
        <i class="fas fa-arrow-left"></i> Voltar
    </a>
</div>

<div class="form-card">
    <form id="form-tutor" novalidate>

        <div class="form-section-title">Dados Pessoais</div>
        <div class="form-grid">
            <div class="form-group full">
                <label>Nome completo *</label>
                <input type="text" id="nome" placeholder="Ex: João da Silva" required />
            </div>
            <div class="form-group">
                <label>CPF *</label>
                <input type="text" id="cpf" placeholder="000.000.000-00" maxlength="14" required />
            </div>
            <div class="form-group">
                <label>Telefone *</label>
                <input type="text" id="telefone" placeholder="(62) 90000-0000" maxlength="15" required />
            </div>
            <div class="form-group full">
                <label>E-mail *</label>
                <input type="email" id="email" placeholder="email@exemplo.com" required />
            </div>
        </div>

        <div class="form-section-title">Endereço</div>
        <div class="form-grid">
            <div class="form-group full">
                <label>Rua</label>
                <input type="text" id="rua" placeholder="Nome da rua" />
            </div>
            <div class="form-group">
                <label>Número</label>
                <input type="text" id="numero" placeholder="Ex: 123" />
            </div>
            <div class="form-group">
                <label>Bairro</label>
                <input type="text" id="bairro" placeholder="Bairro" />
            </div>
            <div class="form-group">
                <label>Cidade</label>
                <input type="text" id="cidade" placeholder="Cidade" />
            </div>
            <div class="form-group">
                <label>Estado (UF)</label>
                <input type="text" id="estado" placeholder="GO" maxlength="2" />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-sm btn-green" id="btn-salvar">
                <i class="fas fa-floppy-disk"></i> Salvar Tutor
            </button>
            <a href="/Tutores" class="btn-cancel">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
document.getElementById('cpf').addEventListener('input', function() {
    let v = this.value.replace(/\D/g,'');
    if (v.length <= 11) {
        v = v.replace(/(\d{3})(\d)/,'$1.$2');
        v = v.replace(/(\d{3})(\d)/,'$1.$2');
        v = v.replace(/(\d{3})(\d{1,2})$/,'$1-$2');
    }
    this.value = v;
});

document.getElementById('telefone').addEventListener('input', function() {
    let v = this.value.replace(/\D/g,'');
    if (v.length <= 11) {
        v = v.replace(/^(\d{2})(\d)/,'($1) $2');
        v = v.replace(/(\d{5})(\d{4})$/,'$1-$2');
    }
    this.value = v;
});

document.getElementById('estado').addEventListener('input', function() {
    this.value = this.value.toUpperCase();
});

document.getElementById('form-tutor').addEventListener('submit', async (e) => {
    e.preventDefault();

    const nome = document.getElementById('nome').value.trim();
    const cpf  = document.getElementById('cpf').value.trim();
    const tel  = document.getElementById('telefone').value.trim();
    const email= document.getElementById('email').value.trim();

    if (!nome || !cpf || !tel || !email) {
        showToast('Preencha todos os campos obrigatórios.', 'error');
        return;
    }

    const btn = document.getElementById('btn-salvar');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Salvando...';

    const payload = {
        nome, cpf, telefone: tel, email,
        rua:    document.getElementById('rua').value.trim(),
        numero: document.getElementById('numero').value.trim(),
        bairro: document.getElementById('bairro').value.trim(),
        cidade: document.getElementById('cidade').value.trim(),
        estado: document.getElementById('estado').value.trim()
    };

    try {
        const res = await fetch('/api/Tutores', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        if (res.ok || res.status === 201) {
            showToast('Tutor cadastrado com sucesso!');
            setTimeout(() => window.location.href = '/Tutores', 1200);
        } else {
            const err = await res.json();
            showToast(err.mensagem || 'Erro ao cadastrar tutor.', 'error');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-floppy-disk"></i> Salvar Tutor';
        }
    } catch {
        showToast('Erro de conexão. Tente novamente.', 'error');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-floppy-disk"></i> Salvar Tutor';
    }
});
</script>
}
