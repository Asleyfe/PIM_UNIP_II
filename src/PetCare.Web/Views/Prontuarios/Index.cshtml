@{
    ViewData["Title"] = "Prontuários Digitais";
}

<style>
    .search-bar { display: flex; gap: 10px; margin-bottom: 20px; }
    .search-bar input { flex: 1; padding: 10px 16px; border: 1px solid var(--cinza-2); border-radius: 50px; font-family: 'DM Sans', sans-serif; font-size: .9rem; outline: none; background: #fff; }
    .search-bar input:focus { border-color: var(--verde-d); }
    .empty-state { text-align: center; padding: 48px 0; color: var(--texto-s); }
    .empty-state i { font-size: 2.5rem; margin-bottom: 12px; display: block; color: var(--cinza-2); }
    .pront-card {
        background: #fff; border-radius: var(--radius);
        box-shadow: 0 2px 10px var(--sombra); margin-bottom: 16px; overflow: hidden;
    }
    .pront-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 24px; cursor: pointer;
        border-bottom: 1px solid var(--cinza);
        transition: background var(--trans);
    }
    .pront-header:hover { background: var(--cinza); }
    .pront-header h3 { font-size: 1rem; }
    .pront-header small { font-size: .78rem; color: var(--texto-s); }
    .pront-body { padding: 20px 24px; display: none; }
    .pront-body.open { display: block; }
    .pront-row { margin-bottom: 12px; }
    .pront-row strong { font-size: .78rem; text-transform: uppercase; color: var(--texto-s); display: block; margin-bottom: 3px; }
    .pront-row p { font-size: .9rem; color: var(--texto); }

    /* Modal novo prontuário */
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.4); z-index:1000; align-items:center; justify-content:center; }
    .modal-overlay.show { display:flex; }
    .modal-box { background:#fff; border-radius:var(--radius); padding:32px; width:100%; max-width:580px; box-shadow:0 8px 40px rgba(0,0,0,.2); max-height:90vh; overflow-y:auto; }
    .modal-box h3 { margin-bottom:20px; }
    .form-group { margin-bottom:14px; display:flex; flex-direction:column; gap:5px; }
    .form-group label { font-size:.82rem; font-weight:600; color:var(--texto-s); }
    .form-group input, .form-group textarea, .form-group select { padding:9px 14px; border:1px solid var(--cinza-2); border-radius:var(--radius-s); font-family:'DM Sans',sans-serif; font-size:.88rem; outline:none; }
    .modal-btns { display:flex; gap:10px; margin-top:20px; }
    .modal-btn { flex:1; padding:10px; border-radius:50px; font-weight:600; cursor:pointer; border:none; font-family:'DM Sans',sans-serif; }
    .modal-btn-cancel { background:var(--cinza); color:var(--texto-s); }
    .modal-btn-save   { background:var(--verde-d); color:#fff; }
</style>

<!-- Modal novo prontuário -->
<div class="modal-overlay" id="modalPront">
    <div class="modal-box">
        <h3><i class="fas fa-notes-medical" style="color:var(--verde-d);margin-right:8px"></i>Novo Prontuário</h3>
        <div class="form-group">
            <label>ID do Agendamento *</label>
            <select id="p-agendId">
                <option value="">Carregando...</option>
            </select>
        </div>
        <div class="form-group">
            <label>Queixa Principal *</label>
            <input type="text" id="p-queixa" placeholder="Motivo da consulta" />
        </div>
        <div class="form-group">
            <label>Relato do Tutor</label>
            <textarea id="p-relato" rows="2" placeholder="O que o tutor relatou..."></textarea>
        </div>
        <div class="form-group">
            <label>Exame Físico</label>
            <textarea id="p-exame" rows="2" placeholder="Resultados do exame físico..."></textarea>
        </div>
        <div class="form-group">
            <label>Diagnóstico</label>
            <textarea id="p-diag" rows="2" placeholder="Diagnóstico do veterinário..."></textarea>
        </div>
        <div class="form-group">
            <label>Prescrição</label>
            <textarea id="p-prescricao" rows="2" placeholder="Medicamentos e posologia..."></textarea>
        </div>
        <div class="form-group">
            <label>Observações</label>
            <textarea id="p-obs" rows="2" placeholder="Observações adicionais..."></textarea>
        </div>
        <div class="modal-btns">
            <button class="modal-btn modal-btn-cancel" onclick="fecharModal()">Cancelar</button>
            <button class="modal-btn modal-btn-save" onclick="salvarProntuario()">Salvar Prontuário</button>
        </div>
    </div>
</div>

<div class="header-container" style="margin-bottom:20px">
    <h1 class="page-title">Prontuários</h1>
    <button class="btn-sm btn-green" onclick="abrirModal()">
        <i class="fas fa-plus"></i> Novo Prontuário
    </button>
</div>

<div class="search-bar">
    <input type="number" id="busca-agendamento" placeholder="Buscar por ID do agendamento..." min="1" />
    <button class="btn-sm btn-green" onclick="buscarPorAgendamento()">
        <i class="fas fa-magnifying-glass"></i> Buscar
    </button>
    <button class="btn-sm" style="background:var(--cinza);color:var(--texto-s)" onclick="carregarProntuarios()">
        <i class="fas fa-list"></i> Todos
    </button>
</div>

<div id="lista-prontuarios">
    <p style="text-align:center;padding:32px;color:var(--texto-s)">Carregando...</p>
</div>

@section Scripts {
<script>
async function carregarAgendamentosProntuario() {
    const select = document.getElementById('p-agendId');
    try {
        const res = await fetch('/api/Agendamentos');
        if (!res.ok) throw new Error();
        const agendamentos = await res.json();
        const concluidos = agendamentos.filter(a => String(a.status).toUpperCase() === 'CONCLUIDO');

        select.innerHTML = '<option value="">Selecione o agendamento...</option>' +
            concluidos.map(a => {
                const data = new Date(a.dataHoraConsulta).toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'short' });
                return `<option value="${a.id}">#${a.id} - ${a.animalNome} / ${a.tutorNome} - ${data}</option>`;
            }).join('');

        if (!concluidos.length) {
            select.innerHTML = '<option value="">Nenhum agendamento concluido</option>';
        }
    } catch {
        select.innerHTML = '<option value="">Erro ao carregar</option>';
    }
}

async function carregarProntuarios() {
    document.getElementById('busca-agendamento').value = '';
    try {
        const res = await fetch('/api/Prontuarios');
        if (!res.ok) throw new Error();
        renderLista(await res.json());
    } catch {
        document.getElementById('lista-prontuarios').innerHTML =
            `<p style="text-align:center;padding:24px;color:var(--rosa-d)"><i class="fas fa-circle-xmark"></i> Erro ao carregar prontuários.</p>`;
    }
}

async function buscarPorAgendamento() {
    const id = document.getElementById('busca-agendamento').value;
    if (!id) return carregarProntuarios();
    try {
        const res = await fetch(`/api/Prontuarios/agendamento/${id}`);
        if (res.status === 404) { renderLista([]); return; }
        if (!res.ok) throw new Error();
        const p = await res.json();
        renderLista(Array.isArray(p) ? p : [p]);
    } catch {
        document.getElementById('lista-prontuarios').innerHTML =
            `<p style="text-align:center;padding:24px;color:var(--rosa-d)">Prontuário não encontrado.</p>`;
    }
}

function renderLista(lista) {
    const div = document.getElementById('lista-prontuarios');
    if (!lista.length) {
        div.innerHTML = `<div class="empty-state"><i class="fas fa-notes-medical"></i>Nenhum prontuário encontrado.</div>`;
        return;
    }
    div.innerHTML = lista.map((p, i) => `
        <div class="pront-card">
            <div class="pront-header" onclick="toggle(this)">
                <div>
                    <h3><i class="fas fa-notes-medical" style="color:var(--verde-d);margin-right:8px"></i>Prontuário #${p.id}</h3>
                    <small>Agendamento ${p.agendamentoId} — ${new Date(p.dataRegistro).toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'short' })}</small>
                </div>
                <i class="fas fa-chevron-down"></i>
            </div>
            <div class="pront-body">
                ${campo('Queixa Principal', p.queixaPrincipal)}
                ${campo('Relato do Tutor', p.relatoTutor)}
                ${campo('Exame Físico', p.exameFisico)}
                ${campo('Diagnóstico', p.diagnostico)}
                ${campo('Prescrição', p.prescricao)}
                ${campo('Observações', p.observacoes)}
            </div>
        </div>
    `).join('');
}

function campo(label, valor) {
    if (!valor) return '';
    return `<div class="pront-row"><strong>${label}</strong><p>${valor}</p></div>`;
}

function toggle(header) {
    const body = header.nextElementSibling;
    body.classList.toggle('open');
    const icon = header.querySelector('.fa-chevron-down, .fa-chevron-up');
    icon.classList.toggle('fa-chevron-down');
    icon.classList.toggle('fa-chevron-up');
}

function abrirModal() { document.getElementById('modalPront').classList.add('show'); }
function fecharModal() { document.getElementById('modalPront').classList.remove('show'); }

async function salvarProntuario() {
    const agendamentoId  = parseInt(document.getElementById('p-agendId').value);
    const queixaPrincipal= document.getElementById('p-queixa').value.trim();

    if (!agendamentoId || !queixaPrincipal) {
        showToast('Preencha ao menos o ID do agendamento e a queixa principal.', 'error');
        return;
    }

    const payload = {
        agendamentoId,
        queixaPrincipal,
        relatoTutor: document.getElementById('p-relato').value.trim() || null,
        exameFisico: document.getElementById('p-exame').value.trim() || null,
        diagnostico: document.getElementById('p-diag').value.trim() || null,
        prescricao:  document.getElementById('p-prescricao').value.trim() || null,
        observacoes: document.getElementById('p-obs').value.trim() || null
    };

    const res = await fetch('/api/Prontuarios', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });

    fecharModal();
    if (res.ok || res.status === 201) {
        showToast('Prontuário salvo com sucesso!');
        carregarProntuarios();
    } else {
        const err = await res.json();
        showToast(err.mensagem || 'Erro ao salvar prontuário.', 'error');
    }
}

carregarAgendamentosProntuario();
carregarProntuarios();
</script>
}
