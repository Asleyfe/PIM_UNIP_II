<div class="sys-logo">
    <i class="fas fa-paw"></i>
    <span class="sys-logo-name">PetCare</span>
</div>
<div class="sys-logo-sep"></div>
<span class="sys-page-title" id="paginaTitulo">@ViewData["Title"]</span>
<div class="sys-spacer"></div>
<div class="sys-notif" title="Notificações">
    <i class="fas fa-bell"></i>
    <span class="notif-badge">3</span>
</div>
<div class="sys-user">
    <div class="sys-avatar"><i class="fas fa-user"></i></div>
    <div class="sys-user-info">
        <small>Bem-vindo,</small>
        <strong id="nomeUsuario">Usuário</strong>
    </div>
</div>
<button class="sys-logout" onclick="fazerLogout()">
    <i class="fas fa-right-from-bracket"></i> Sair
</button>
