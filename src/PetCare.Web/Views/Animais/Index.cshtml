@{
    ViewData["Title"] = "Gestão de Animais";
}

<style>
    .search-bar { display: flex; gap: 10px; margin-bottom: 20px; }
    .search-bar input {
        flex: 1; padding: 10px 16px; border: 1px solid var(--cinza-2);
        border-radius: 50px; font-family: 'DM Sans', sans-serif;
        font-size: .9rem; outline: none; background: #fff;
    }
    .search-bar input:focus { border-color: var(--verde-d); }
    .badge { padding: 3px 10px; border-radius: 50px; font-size: .75rem; font-weight: 600; }
    .badge-m { background: var(--azul-l); color: var(--azul); }
    .badge-f { background: var(--rosa-l); color: var(--rosa-d); }
    .badge-filhote { background: #fff9e0; color: #d4a017; }
    .action-btns { display: flex; gap: 6px; }
    .btn-icon { width: 32px; height: 32px; border-radius: 8px; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: .85rem; transition: var(--trans); }
    .btn-icon.del { background: var(--rosa-l); color: var(--rosa-d); }
    .btn-icon.del:hover { background: var(--rosa-d); color: #fff; }
    .empty-state { text-align: center; padding: 48px 0; color: var(--texto-s); }
    .empty-state i { font-size: 2.5rem; margin-bottom: 12px; display: block; color: var(--cinza-2); }
</style>

<div class="header-container" style="margin-bottom:20px">
    <h1 class="page-title">Animais</h1>
    <a href="/Animais/Cadastro" class="btn-sm btn-green">
        <i class="fas fa-plus"></i> Novo Animal
    </a>
</div>

<div class="search-bar">
    <input type="text" id="busca" placeholder="Filtrar por nome..." oninput="filtrar(this.value)" />
    <button class="btn-sm btn-green" onclick="carregarAnimais()">
        <i class="fas fa-rotate-right"></i>
    </button>
</div>

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Nome</th>
                <th>Sexo</th>
                <th>Peso (kg)</th>
                <th>Idade</th>
                <th>Tutor ID</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody id="tabela-body">
            <tr><td colspan="7" style="text-align:center;padding:32px;color:var(--texto-s)">Carregando...</td></tr>
        </tbody>
    </table>
</div>

@section Scripts {
<script>
let todosAnimais = [];

async function carregarAnimais() {
    try {
        const res = await fetch('/api/Animais');
        if (!res.ok) throw new Error();
        todosAnimais = await res.json();
        renderTabela(todosAnimais);
    } catch {
        document.getElementById('tabela-body').innerHTML =
            `<tr><td colspan="7" style="text-align:center;padding:24px;color:var(--rosa-d)"><i class="fas fa-circle-xmark"></i> Erro ao carregar animais.</td></tr>`;
    }
}

function filtrar(termo) {
    const t = termo.toLowerCase();
    renderTabela(todosAnimais.filter(a => a.nome.toLowerCase().includes(t)));
}

function renderTabela(animais) {
    const tbody = document.getElementById('tabela-body');
    if (!animais.length) {
        tbody.innerHTML = `<tr><td colspan="7"><div class="empty-state"><i class="fas fa-paw"></i>Nenhum animal encontrado.</div></td></tr>`;
        return;
    }
    tbody.innerHTML = animais.map(a => `
        <tr>
            <td>${a.id}</td>
            <td>
                <strong>${a.nome}</strong>
                ${a.ehFilhote ? '<span class="badge badge-filhote" style="margin-left:6px">Filhote</span>' : ''}
            </td>
            <td><span class="badge ${a.sexo === 'M' ? 'badge-m' : 'badge-f'}">${a.sexo === 'M' ? 'Macho' : 'Fêmea'}</span></td>
            <td>${a.peso.toFixed(2)}</td>
            <td>${a.idadeAnos} ${a.idadeAnos === 1 ? 'ano' : 'anos'}</td>
            <td>${a.tutorId}</td>
            <td>
                <div class="action-btns">
                    <button class="btn-icon del" title="Remover" onclick="remover(${a.id}, '${a.nome}')">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </td>
        </tr>
    `).join('');
}

async function remover(id, nome) {
    if (!confirm(`Remover o animal "${nome}"?`)) return;
    const res = await fetch(`/api/Animais/${id}`, { method: 'DELETE' });
    if (res.ok) {
        showToast(`Animal "${nome}" removido.`);
        carregarAnimais();
    } else {
        showToast('Erro ao remover animal.', 'error');
    }
}

carregarAnimais();
</script>
}
