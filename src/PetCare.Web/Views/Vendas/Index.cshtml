@{
    ViewData["Title"] = "Vendas e Serviços";
}

<style>
    .search-bar { display: flex; gap: 10px; margin-bottom: 20px; }
    .search-bar input { flex: 1; padding: 10px 16px; border: 1px solid var(--cinza-2); border-radius: 50px; font-family: 'DM Sans', sans-serif; font-size: .9rem; outline: none; background: #fff; }
    .search-bar input:focus { border-color: var(--verde-d); }
    .empty-state { text-align: center; padding: 48px 0; color: var(--texto-s); }
    .empty-state i { font-size: 2.5rem; margin-bottom: 12px; display: block; color: var(--cinza-2); }
    .badge-pgto { padding: 3px 10px; border-radius: 50px; font-size: .75rem; font-weight: 600; background: var(--azul-l); color: var(--azul); }

    /* Modal nova venda */
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.4); z-index:1000; align-items:center; justify-content:center; }
    .modal-overlay.show { display:flex; }
    .modal-box { background:#fff; border-radius:var(--radius); padding:32px; width:100%; max-width:560px; box-shadow:0 8px 40px rgba(0,0,0,.2); max-height:90vh; overflow-y:auto; }
    .modal-box h3 { margin-bottom:20px; }
    .form-group { margin-bottom:14px; display:flex; flex-direction:column; gap:5px; }
    .form-group label { font-size:.82rem; font-weight:600; color:var(--texto-s); }
    .form-group input, .form-group select { padding:9px 14px; border:1px solid var(--cinza-2); border-radius:var(--radius-s); font-family:'DM Sans',sans-serif; font-size:.88rem; outline:none; }
    .itens-lista { margin:16px 0; }
    .item-row { display:grid; grid-template-columns:1fr 80px 100px 32px; gap:8px; align-items:center; margin-bottom:8px; }
    .item-row input, .item-row select { padding:8px 10px; border:1px solid var(--cinza-2); border-radius:8px; font-size:.85rem; font-family:'DM Sans',sans-serif; outline:none; }
    .btn-remove-item { width:32px; height:32px; border-radius:8px; border:none; background:var(--rosa-l); color:var(--rosa-d); cursor:pointer; display:flex; align-items:center; justify-content:center; }
    .modal-btns { display:flex; gap:10px; margin-top:20px; }
    .modal-btn { flex:1; padding:10px; border-radius:50px; font-weight:600; cursor:pointer; border:none; font-family:'DM Sans',sans-serif; }
    .modal-btn-cancel { background:var(--cinza); color:var(--texto-s); }
    .modal-btn-save   { background:var(--verde-d); color:#fff; }
</style>

<!-- Modal nova venda -->
<div class="modal-overlay" id="modalVenda">
    <div class="modal-box">
        <h3><i class="fas fa-cart-shopping" style="color:var(--verde-d);margin-right:8px"></i>Nova Venda</h3>
        <div class="form-group">
            <label>ID do Tutor *</label>
            <select id="v-tutorId">
                <option value="">Carregando...</option>
            </select>
        </div>
        <div class="form-group">
            <label>Forma de Pagamento *</label>
            <select id="v-pagamento">
                <option value="">Selecione...</option>
                <option value="Dinheiro">Dinheiro</option>
                <option value="Cartao_Credito">Cartão de Crédito</option>
                <option value="Cartao_Debito">Cartão de Débito</option>
                <option value="Pix">Pix</option>
            </select>
        </div>
        <div class="form-group">
            <label>Observação</label>
            <input type="text" id="v-obs" placeholder="Opcional" />
        </div>

        <div style="font-size:.82rem;font-weight:700;color:var(--texto-s);text-transform:uppercase;margin-bottom:8px">Itens</div>
        <div class="itens-lista" id="itens-lista">
            <div class="item-row">
                <select class="item-prod" onchange="preencherPrecoProduto(this)">
                    <option value="">Carregando...</option>
                </select>
                <input type="number" placeholder="Qtd" min="1" value="1" class="item-qty" />
                <input type="number" placeholder="Preço R$" min="0" step="0.01" class="item-preco" />
                <button class="btn-remove-item" onclick="removerItem(this)"><i class="fas fa-minus"></i></button>
            </div>
        </div>
        <button class="btn-sm" style="background:var(--cinza);color:var(--texto)" onclick="adicionarItem()">
            <i class="fas fa-plus"></i> Adicionar Item
        </button>

        <div class="modal-btns" style="margin-top:24px">
            <button class="modal-btn modal-btn-cancel" onclick="fecharModal()">Cancelar</button>
            <button class="modal-btn modal-btn-save" onclick="salvarVenda()">Finalizar Venda</button>
        </div>
    </div>
</div>

<div class="header-container" style="margin-bottom:20px">
    <h1 class="page-title">Vendas</h1>
    <button class="btn-sm btn-green" onclick="abrirModal()">
        <i class="fas fa-plus"></i> Nova Venda
    </button>
</div>

<div class="search-bar">
    <input type="text" id="busca" placeholder="Filtrar por tutor ou forma de pagamento..." oninput="filtrar(this.value)" />
    <button class="btn-sm btn-green" onclick="carregarVendas()">
        <i class="fas fa-rotate-right"></i>
    </button>
</div>

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Tutor</th>
                <th>Data</th>
                <th>Forma Pgto</th>
                <th>Valor Total</th>
                <th>Observação</th>
            </tr>
        </thead>
        <tbody id="tabela-body">
            <tr><td colspan="6" style="text-align:center;padding:32px;color:var(--texto-s)">Carregando...</td></tr>
        </tbody>
    </table>
</div>

@section Scripts {
<script>
let todasVendas = [];
let todosProdutos = [];

async function carregarCombosVenda() {
    const [tutoresRes, produtosRes] = await Promise.all([
        fetch('/api/Tutores'),
        fetch('/api/Produtos')
    ]);

    const tutores = tutoresRes.ok ? await tutoresRes.json() : [];
    todosProdutos = produtosRes.ok ? await produtosRes.json() : [];

    document.getElementById('v-tutorId').innerHTML =
        '<option value="">Selecione o tutor...</option>' +
        tutores.map(t => `<option value="${t.id}">${t.nome} - CPF ${t.cpf}</option>`).join('');

    document.querySelectorAll('.item-prod').forEach(preencherSelectProdutos);
}

function preencherSelectProdutos(select) {
    select.innerHTML =
        '<option value="">Selecione o produto...</option>' +
        todosProdutos.map(p => `<option value="${p.id}" data-preco="${p.preco}">${p.nome} - R$ ${Number(p.preco).toFixed(2).replace('.', ',')}</option>`).join('');
}

function preencherPrecoProduto(select) {
    const option = select.selectedOptions[0];
    const preco = option?.dataset?.preco;
    if (preco) {
        select.closest('.item-row').querySelector('.item-preco').value = Number(preco).toFixed(2);
    }
}

async function carregarVendas() {
    try {
        const res = await fetch('/api/Vendas');
        if (!res.ok) throw new Error();
        todasVendas = await res.json();
        renderTabela(todasVendas);
    } catch {
        document.getElementById('tabela-body').innerHTML =
            `<tr><td colspan="6" style="text-align:center;padding:24px;color:var(--rosa-d)"><i class="fas fa-circle-xmark"></i> Erro ao carregar vendas.</td></tr>`;
    }
}

function filtrar(termo) {
    const t = termo.toLowerCase();
    renderTabela(todasVendas.filter(v =>
        v.tutorNome.toLowerCase().includes(t) || v.formaPagamento.toLowerCase().includes(t)
    ));
}

function renderTabela(vendas) {
    const tbody = document.getElementById('tabela-body');
    if (!vendas.length) {
        tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state"><i class="fas fa-cart-shopping"></i>Nenhuma venda registrada.</div></td></tr>`;
        return;
    }
    tbody.innerHTML = vendas.map(v => `
        <tr>
            <td>${v.id}</td>
            <td><strong>${v.tutorNome}</strong></td>
            <td>${new Date(v.dataVenda).toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'short' })}</td>
            <td><span class="badge-pgto">${v.formaPagamento.replace('_',' ')}</span></td>
            <td><strong>R$ ${v.valorTotal.toFixed(2).replace('.',',')}</strong></td>
            <td>${v.observacao || '—'}</td>
        </tr>
    `).join('');
}

function abrirModal() { document.getElementById('modalVenda').classList.add('show'); }
function fecharModal() { document.getElementById('modalVenda').classList.remove('show'); }

function adicionarItem() {
    const row = document.createElement('div');
    row.className = 'item-row';
    row.innerHTML = `
        <select class="item-prod" onchange="preencherPrecoProduto(this)"></select>
        <input type="number" placeholder="Qtd" min="1" value="1" class="item-qty" />
        <input type="number" placeholder="Preço R$" min="0" step="0.01" class="item-preco" />
        <button class="btn-remove-item" onclick="removerItem(this)"><i class="fas fa-minus"></i></button>
    `;
    document.getElementById('itens-lista').appendChild(row);
    preencherSelectProdutos(row.querySelector('.item-prod'));
}

function removerItem(btn) {
    const lista = document.getElementById('itens-lista');
    if (lista.children.length > 1) btn.closest('.item-row').remove();
}

async function salvarVenda() {
    const tutorId = parseInt(document.getElementById('v-tutorId').value);
    const pagamento = document.getElementById('v-pagamento').value;

    if (!tutorId || !pagamento) { showToast('Preencha tutor e forma de pagamento.', 'error'); return; }

    const rows = document.querySelectorAll('#itens-lista .item-row');
    const itens = [];
    for (const row of rows) {
        const prod  = parseInt(row.querySelector('.item-prod').value);
        const qty   = parseInt(row.querySelector('.item-qty').value);
        const preco = parseFloat(row.querySelector('.item-preco').value);
        if (!prod || !qty || !preco) { showToast('Preencha todos os campos dos itens.', 'error'); return; }
        itens.push({ produtoId: prod, quantidade: qty, precoUnitario: preco });
    }

    const payload = {
        tutorId,
        formaPagamento: pagamento,
        observacao: document.getElementById('v-obs').value.trim() || null,
        itens
    };

    const res = await fetch('/api/Vendas', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });

    fecharModal();
    if (res.ok || res.status === 201) {
        showToast('Venda registrada com sucesso!');
        carregarVendas();
    } else {
        const err = await res.json();
        showToast(err.mensagem || 'Erro ao registrar venda.', 'error');
    }
}

carregarCombosVenda();
carregarVendas();
</script>
}
